# Social Media API Configuration
# Copy this file to .env.local and fill in your actual API credentials

# ===================================
# INSTAGRAM CONFIGURATION
# ===================================
# How to get Instagram credentials:
# 1. Create a Facebook Developer account at https://developers.facebook.com
# 2. Create a new app and add Instagram Basic Display
# 3. Get your User ID and Access Token
# Documentation: https://developers.facebook.com/docs/instagram-basic-display-api/getting-started

INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
INSTAGRAM_USER_ID=your_instagram_user_id_here

# ===================================
# TWITTER/X CONFIGURATION
# ===================================
# How to get Twitter credentials:
# 1. Apply for a Twitter Developer account at https://developer.twitter.com
# 2. Create a new app in the Developer Portal
# 3. Generate a Bearer Token under the "Keys and tokens" tab
# Documentation: https://developer.twitter.com/en/docs/authentication/oauth-2-0/bearer-tokens

TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here
TWITTER_USERNAME=your_twitter_username_here

# ===================================
# TIKTOK CONFIGURATION
# ===================================
# How to get TikTok credentials:
# 1. Register for TikTok for Developers at https://developers.tiktok.com
# 2. Create a new app
# 3. Get your Access Token from the app dashboard
# Documentation: https://developers.tiktok.com/doc/overview

TIKTOK_ACCESS_TOKEN=your_tiktok_access_token_here
TIKTOK_USERNAME=your_tiktok_username_here

# ===================================
# SUBSTACK CONFIGURATION
# ===================================
# How to set up Substack integration:
# 1. Your Substack publication URL (e.g., https://yourname.substack.com)
# 2. No API key needed - just the base URL of your publication
# Documentation: https://support.substack.com/hc/en-us

NEXT_PUBLIC_SUBSTACK_URL=https://yourname.substack.com

# ===================================
# KLAVIYO CONFIGURATION
# ===================================
# How to set up Klaviyo:
# 1. Go to Klaviyo Dashboard → Settings → API Keys
# 2. Create a Private API Key with full access
# 3. For List ID: Go to Audience → Lists & Segments → Click your list
#    The List ID is in the URL: https://www.klaviyo.com/list/XXXXXX
# Documentation: https://developers.klaviyo.com/en/reference/api_overview

KLAVIYO_PRIVATE_API_KEY=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KLAVIYO_WAITLIST_LIST_ID=XXXXXX

# ===================================
# SPOTIFY CONFIGURATION
# ===================================
# How to set up Spotify:
# 1. Go to https://developer.spotify.com/dashboard
# 2. Create a new app
# 3. Copy the Client ID and Client Secret
# Documentation: https://developer.spotify.com/documentation/web-api

SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# ===================================
# NOTES
# ===================================
# - Never commit .env.local to version control
# - Keep your API tokens secure and never share them publicly
# - API tokens may expire and need to be refreshed periodically
# - For Instagram, you'll need to refresh your access token every 60 days
# - For production, consider using environment variables in your hosting platform
